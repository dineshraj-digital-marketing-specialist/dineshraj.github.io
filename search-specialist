<script>
/* ── Loader ──────────────────────────── */
window.addEventListener('load', () => {
  setTimeout(() => { document.getElementById('loader').classList.add('hidden'); }, 2000);
});

/* ── Nav scroll ──────────────────────── */
(function() {
  const nav = document.getElementById('navbar');
  const btt = document.getElementById('btt');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('raised', window.scrollY > 40);
    btt.classList.toggle('visible', window.scrollY > 400);
  }, { passive: true });
})();

/* ── Hamburger ───────────────────────── */
(function() {
  const btn = document.getElementById('hamburger');
  const mn = document.getElementById('mobileNav');
  btn.addEventListener('click', () => {
    const open = btn.classList.toggle('open');
    btn.setAttribute('aria-expanded', open);
    mn.classList.toggle('open', open);
    document.body.style.overflow = open ? 'hidden' : '';
  });
  mn.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
    btn.classList.remove('open'); btn.setAttribute('aria-expanded', false);
    mn.classList.remove('open'); document.body.style.overflow = '';
  }));
})();

/* ── Scroll Reveal ───────────────────── */
(function() {
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
})();

/* ── Counters ────────────────────────── */
(function() {
  function animCount(el) {
    const target = +el.dataset.target;
    const dur = 1800; const start = performance.now();
    const tick = now => {
      const p = Math.min((now - start) / dur, 1);
      const e = 1 - Math.pow(1 - p, 3);
      el.textContent = Math.floor(e * target) + (p === 1 ? '+' : '');
      if (p < 1) requestAnimationFrame(tick);
      else el.textContent = target + '+';
    };
    requestAnimationFrame(tick);
  }
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting && e.target.dataset.target) { animCount(e.target); obs.unobserve(e.target); } });
  }, { threshold: 0.5 });
  document.querySelectorAll('[data-target]').forEach(el => obs.observe(el));
})();

/* ── Skill bars ──────────────────────── */
(function() {
  function animBars(panel) {
    panel.querySelectorAll('.si-fill').forEach(bar => {
      bar.style.width = bar.dataset.width + '%';
    });
  }
  // Animate visible panel on load
  const activePanel = document.querySelector('.skill-panel.active');
  if (activePanel) {
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) { animBars(activePanel); obs.unobserve(e.target); } });
    }, { threshold: 0.2 });
    obs.observe(activePanel);
  }
})();

/* ── Skill tabs ──────────────────────── */
(function() {
  const cats = document.querySelectorAll('.skill-cat');
  cats.forEach(btn => {
    btn.addEventListener('click', () => {
      cats.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected', false); });
      btn.classList.add('active'); btn.setAttribute('aria-selected', true);
      const panelId = 'panel-' + btn.dataset.panel;
      document.querySelectorAll('.skill-panel').forEach(p => p.classList.remove('active'));
      const panel = document.getElementById(panelId);
      panel.classList.add('active');
      // Animate bars in the newly shown panel
      setTimeout(() => {
        panel.querySelectorAll('.si-fill').forEach(bar => { bar.style.width = bar.dataset.width + '%'; });
      }, 50);
    });
  });
})();

/* ── Hero grid responsive ────────────── */
(function() {
  const heroGrid = document.querySelector('.hero-top-grid');
  const serpStrip = document.querySelector('.serp-strip');
  function check() {
    if (window.innerWidth < 900) {
      if (heroGrid) heroGrid.style.gridTemplateColumns = '1fr';
      if (serpStrip) serpStrip.style.gridTemplateColumns = '1fr';
    } else {
      if (heroGrid) heroGrid.style.gridTemplateColumns = '1fr 1.1fr';
      if (serpStrip) serpStrip.style.gridTemplateColumns = 'repeat(3,1fr)';
    }
  }
  check(); window.addEventListener('resize', check, { passive: true });
})();

/* ── Contact form ────────────────────── */
(function() {
  const form = document.getElementById('contactForm');
  const msg = document.getElementById('formSuccess');
  if (!form) return;
  form.addEventListener('submit', e => {
    e.preventDefault();
    const btn = form.querySelector('.form-submit');
    btn.textContent = 'Sending...'; btn.disabled = true;
    setTimeout(() => {
      btn.textContent = 'Send Message'; btn.disabled = false;
      msg.classList.add('visible'); form.reset();
      setTimeout(() => msg.classList.remove('visible'), 5000);
    }, 1200);
  });
})();
</script>
