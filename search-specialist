  <!-- Fonts: Space Grotesk (display) + IBM Plex Mono (code/terminal) + Inter (body) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@300;400;500&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

  <style>
    /* ═══════════════════════════════════════
       DESIGN TOKENS
       Palette: Off-white base · Ink type · 
       Deep teal primary · Electric blue accent
       Signature: SERP / AI Answer Box as UI components
    ═══════════════════════════════════════ */
    :root {
      --bg:        #F7F8FA;
      --bg-white:  #FFFFFF;
      --bg-code:   #0F1117;
      --ink:       #0D1117;
      --ink-mid:   #3D4452;
      --ink-dim:   #8792A2;

      --teal:      #0B6E6E;
      --teal-dark: #084F4F;
      --teal-pale: #E8F4F4;
      --teal-mid:  #C2E0E0;
      --blue:      #1A56DB;
      --blue-pale: #EBF2FF;
      --green:     #0E7C4A;
      --green-pale:#E6F7EF;
      --amber:     #B45309;
      --amber-pale:#FEF3C7;
      --red:       #B91C1C;

      --border:    #E2E6EC;
      --border-dark: #C8D0DC;

      --font-display: 'Space Grotesk', sans-serif;
      --font-mono:    'IBM Plex Mono', monospace;
      --font-body:    'Inter', sans-serif;

      --radius:    8px;
      --radius-lg: 14px;
      --shadow-sm: 0 1px 3px rgba(0,0,0,0.07), 0 1px 2px rgba(0,0,0,0.04);
      --shadow-md: 0 4px 16px rgba(0,0,0,0.08), 0 1px 4px rgba(0,0,0,0.04);
      --shadow-lg: 0 12px 40px rgba(0,0,0,0.10), 0 2px 8px rgba(0,0,0,0.04);

      --transition: 0.22s cubic-bezier(0.4,0,0.2,1);
    }

    /* ─── Reset ─────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: 16px; }
    body {
      background: var(--bg);
      color: var(--ink);
      font-family: var(--font-body);
      font-size: 1rem;
      line-height: 1.7;
      overflow-x: hidden;
    }
    a { color: var(--blue); text-decoration: none; }
    a:hover { text-decoration: underline; }
    img { max-width: 100%; display: block; }
    ul { list-style: none; }

    /* ─── Loader ─────────────────────────────── */
    #loader {
      position: fixed; inset: 0; z-index: 9999;
      background: var(--bg-code);
      display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 1.5rem;
      transition: opacity 0.6s ease, visibility 0.6s ease;
    }
    #loader.hidden { opacity: 0; visibility: hidden; }
    .loader-query {
      font-family: var(--font-mono); font-size: 1rem; color: #8792A2;
      letter-spacing: 0.02em;
    }
    .loader-query .cursor-blink {
      display: inline-block; width: 10px; height: 1.2em;
      background: #0B6E6E; animation: blink 0.9s infinite; vertical-align: text-bottom;
    }
    .loader-bar-track {
      width: 260px; height: 2px; background: rgba(255,255,255,0.08); border-radius: 2px;
    }
    .loader-bar-fill {
      height: 100%; background: linear-gradient(90deg, #0B6E6E, #1A56DB);
      border-radius: 2px; animation: loadFill 1.8s cubic-bezier(.4,0,.2,1) forwards;
    }
    .loader-label {
      font-family: var(--font-mono); font-size: 0.65rem; color: #3D4452;
      letter-spacing: 0.2em; text-transform: uppercase;
    }
    @keyframes loadFill { to { width: 100%; } }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

    /* ─── Nav ────────────────────────────────── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 500;
      background: rgba(247,248,250,0.92);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
      padding: 0 3rem;
      display: flex; align-items: center; justify-content: space-between;
      height: 60px;
      transition: box-shadow var(--transition);
    }
    nav.raised { box-shadow: var(--shadow-sm); }
    .nav-brand {
      font-family: var(--font-display); font-weight: 700; font-size: 1rem;
      color: var(--ink); letter-spacing: -0.01em;
      display: flex; align-items: center; gap: 0.5rem;
    }
    .nav-brand .brand-badge {
      font-family: var(--font-mono); font-size: 0.6rem; font-weight: 400;
      background: var(--teal); color: white;
      padding: 0.15rem 0.45rem; border-radius: 3px; letter-spacing: 0.08em;
    }
    .nav-links {
      display: flex; align-items: center; gap: 2rem;
    }
    .nav-links a {
      font-size: 0.85rem; font-weight: 500; color: var(--ink-mid);
      transition: color var(--transition);
    }
    .nav-links a:hover { color: var(--teal); text-decoration: none; }
    .nav-cta {
      font-size: 0.82rem; font-weight: 600;
      background: var(--teal); color: white;
      padding: 0.5rem 1.2rem; border-radius: var(--radius);
      transition: background var(--transition), box-shadow var(--transition);
    }
    .nav-cta:hover { background: var(--teal-dark); text-decoration: none; box-shadow: var(--shadow-sm); }

    .hamburger {
      display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 4px;
      background: none; border: none;
    }
    .hamburger span { width: 22px; height: 1.5px; background: var(--ink); display: block; transition: all 0.3s; }
    .hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

    .mobile-nav {
      display: none; position: fixed; inset: 0; z-index: 490; top: 60px;
      background: var(--bg-white); flex-direction: column;
      padding: 2rem; gap: 1.5rem;
    }
    .mobile-nav.open { display: flex; }
    .mobile-nav a { font-size: 1.3rem; font-weight: 600; color: var(--ink); }

    /* ─── Sections ───────────────────────────── */
    section { padding: 7rem 3rem; position: relative; }
    .container { max-width: 1100px; margin: 0 auto; }

    /* Section label */
    .sec-label {
      font-family: var(--font-mono); font-size: 0.7rem; font-weight: 500;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--teal); margin-bottom: 0.75rem;
      display: flex; align-items: center; gap: 0.5rem;
    }
    .sec-label::before { content: ''; width: 20px; height: 1px; background: var(--teal); }
    .sec-title {
      font-family: var(--font-display); font-size: clamp(2rem,4vw,3rem);
      font-weight: 700; line-height: 1.1; letter-spacing: -0.03em;
      color: var(--ink); margin-bottom: 1rem;
    }
    .sec-title em { color: var(--teal); font-style: normal; }
    .sec-sub { font-size: 1.05rem; color: var(--ink-mid); max-width: 560px; line-height: 1.75; }

    /* Reveal */
    .reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
    .reveal.visible { opacity: 1; transform: none; }
    .delay-1 { transition-delay: 0.08s; }
    .delay-2 { transition-delay: 0.16s; }
    .delay-3 { transition-delay: 0.24s; }
    .delay-4 { transition-delay: 0.32s; }
    .delay-5 { transition-delay: 0.40s; }

    /* ════════════════════════════════════════
       HERO — Search bar as identity statement
    ════════════════════════════════════════ */
    #hero {
      min-height: 100vh;
      background: var(--bg-code);
      display: flex; align-items: center;
      padding-top: 5rem; padding-bottom: 3rem;
      overflow: hidden; position: relative;
    }

    /* Subtle grid */
    #hero::before {
      content: ''; position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(11,110,110,0.06) 1px, transparent 1px),
        linear-gradient(90deg, rgba(11,110,110,0.06) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
    }

    .hero-inner {
      max-width: 1100px; margin: 0 auto; width: 100%;
      display: flex; flex-direction: column; gap: 3.5rem;
    }

    /* Top: eyebrow + name */
    .hero-top {}
    .hero-eyebrow {
      font-family: var(--font-mono); font-size: 0.75rem; color: #0B6E6E;
      letter-spacing: 0.25em; text-transform: uppercase; margin-bottom: 1.5rem;
      display: flex; align-items: center; gap: 0.75rem;
    }
    .hero-eyebrow span { color: #2DD4BF; }
    .live-dot {
      width: 7px; height: 7px; border-radius: 50%; background: #10B981;
      animation: livePulse 2s infinite;
    }
    @keyframes livePulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(0.8)} }

    .hero-name {
      font-family: var(--font-display); font-size: clamp(3rem,7vw,5.5rem);
      font-weight: 700; color: #F7F8FA; line-height: 1.0;
      letter-spacing: -0.04em; margin-bottom: 0.75rem;
    }
    .hero-name .name-teal { color: #2DD4BF; }
    .hero-tagline {
      font-family: var(--font-display); font-size: clamp(1rem,2vw,1.35rem);
      color: #8792A2; font-weight: 400; letter-spacing: -0.01em;
    }
    .hero-tagline strong { color: #CBD5E1; font-weight: 600; }

    /* The signature: AI Answer Box */
    .ai-answer-box {
      background: #0F1117;
      border: 1px solid #1E2530;
      border-radius: var(--radius-lg);
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0,0,0,0.4);
      max-width: 760px;
    }
    .aab-header {
      background: #161B25; border-bottom: 1px solid #1E2530;
      padding: 0.85rem 1.25rem;
      display: flex; align-items: center; gap: 0.75rem;
    }
    .aab-icon {
      width: 22px; height: 22px; border-radius: 50%;
      background: linear-gradient(135deg, #0B6E6E, #1A56DB);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.65rem; color: white; font-weight: 700;
    }
    .aab-source {
      font-family: var(--font-mono); font-size: 0.68rem; color: #3D4452;
      letter-spacing: 0.05em;
    }
    .aab-source strong { color: #8792A2; }
    .aab-badge {
      margin-left: auto; font-family: var(--font-mono); font-size: 0.58rem;
      background: rgba(11,110,110,0.2); color: #2DD4BF;
      border: 1px solid rgba(11,110,110,0.3);
      padding: 0.2rem 0.5rem; border-radius: 3px; letter-spacing: 0.1em; text-transform: uppercase;
    }
    .aab-body { padding: 1.5rem 1.25rem; }
    .aab-query {
      font-family: var(--font-mono); font-size: 0.72rem; color: #3D4452;
      margin-bottom: 1rem; letter-spacing: 0.04em;
    }
    .aab-query .q-label { color: #0B6E6E; margin-right: 0.4rem; }
    .aab-answer {
      font-size: 0.95rem; color: #CBD5E1; line-height: 1.8;
      margin-bottom: 1.25rem;
    }
    .aab-answer strong { color: #F1F5F9; }
    .aab-answer .hl { color: #2DD4BF; font-weight: 600; }
    .aab-chips { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .aab-chip {
      font-family: var(--font-mono); font-size: 0.65rem; color: #8792A2;
      border: 1px solid #1E2530; border-radius: 4px;
      padding: 0.3rem 0.7rem; letter-spacing: 0.05em;
      transition: border-color var(--transition), color var(--transition);
    }
    .aab-chip:hover { border-color: #0B6E6E; color: #2DD4BF; cursor: default; }

    /* SERP result cards */
    .serp-results { display: flex; flex-direction: column; gap: 0; }
    .serp-result {
      background: #0F1117; border: 1px solid #1E2530;
      border-radius: var(--radius-lg);
      padding: 1.2rem 1.4rem;
      display: flex; align-items: flex-start; gap: 1rem;
      transition: border-color var(--transition), background var(--transition);
    }
    .serp-result:hover { border-color: rgba(11,110,110,0.4); background: #161B25; }
    .serp-pos {
      font-family: var(--font-mono); font-size: 1.4rem; font-weight: 500;
      color: rgba(11,110,110,0.35); min-width: 28px; line-height: 1; padding-top: 2px;
    }
    .serp-content {}
    .serp-url {
      font-family: var(--font-mono); font-size: 0.65rem; color: #3D4452;
      margin-bottom: 0.3rem; letter-spacing: 0.03em;
    }
    .serp-url span { color: #0B6E6E; }
    .serp-title {
      font-family: var(--font-display); font-size: 1rem; font-weight: 600;
      color: #93C5FD; margin-bottom: 0.35rem; line-height: 1.3;
    }
    .serp-snippet { font-size: 0.82rem; color: #64748B; line-height: 1.6; }
    .serp-snippet strong { color: #94A3B8; }

    /* Hero bottom row */
    .hero-bottom {
      display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;
      align-items: start;
    }
    .hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: center; }
    .btn-primary {
      font-size: 0.88rem; font-weight: 600;
      background: #0B6E6E; color: white;
      padding: 0.75rem 1.75rem; border-radius: var(--radius);
      border: none; display: inline-block;
      transition: background var(--transition), box-shadow var(--transition), transform var(--transition);
    }
    .btn-primary:hover { background: #084F4F; text-decoration: none; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(11,110,110,0.3); }
    .btn-outline {
      font-size: 0.88rem; font-weight: 600;
      border: 1px solid #1E2530; color: #CBD5E1;
      padding: 0.75rem 1.75rem; border-radius: var(--radius);
      display: inline-block;
      transition: border-color var(--transition), color var(--transition), background var(--transition);
    }
    .btn-outline:hover { border-color: #0B6E6E; color: #2DD4BF; background: rgba(11,110,110,0.05); text-decoration: none; }
    .hero-stats { display: flex; gap: 2rem; }
    .h-stat {}
    .h-stat-num {
      font-family: var(--font-display); font-size: 1.8rem; font-weight: 700;
      color: #F1F5F9; letter-spacing: -0.03em; line-height: 1;
    }
    .h-stat-label { font-family: var(--font-mono); font-size: 0.62rem; color: #3D4452; letter-spacing: 0.1em; text-transform: uppercase; margin-top: 0.2rem; }

    /* Scroll cue */
    .scroll-hint {
      position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
      font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.2em;
      color: #3D4452; text-transform: uppercase;
      display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
      animation: scrollBob 2.5s ease-in-out infinite;
    }
    .scroll-hint::after {
      content: ''; width: 1px; height: 40px;
      background: linear-gradient(to bottom, #0B6E6E, transparent);
    }
    @keyframes scrollBob { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(6px)} }

    /* ════════════════════════════════════════
       ABOUT / PHILOSOPHY
    ════════════════════════════════════════ */
    #about { background: var(--bg-white); }
    .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
    .about-text p { color: var(--ink-mid); font-size: 1.02rem; line-height: 1.85; margin-bottom: 1.25rem; }
    .about-text p strong { color: var(--ink); }
    .about-text p .hl { color: var(--teal); font-weight: 600; }

    /* Schema card — the right side */
    .schema-card {
      background: var(--bg-code); border-radius: var(--radius-lg);
      border: 1px solid #1E2530; overflow: hidden;
      box-shadow: var(--shadow-lg);
    }
    .schema-topbar {
      background: #161B25; border-bottom: 1px solid #1E2530;
      padding: 0.75rem 1rem;
      display: flex; align-items: center; gap: 0.5rem;
    }
    .s-dot { width: 10px; height: 10px; border-radius: 50%; }
    .s-dot.r { background: #FF5F57; } .s-dot.y { background: #FEBC2E; } .s-dot.g { background: #28C840; }
    .schema-filename {
      font-family: var(--font-mono); font-size: 0.65rem; color: #3D4452;
      margin-left: 0.5rem; letter-spacing: 0.05em;
    }
    .schema-body { padding: 1.5rem; font-family: var(--font-mono); font-size: 0.78rem; line-height: 2; }
    .tok-key   { color: #93C5FD; }
    .tok-str   { color: #86EFAC; }
    .tok-num   { color: #FCA5A5; }
    .tok-bool  { color: #FCD34D; }
    .tok-punc  { color: #64748B; }
    .tok-url   { color: #67E8F9; }
    .tok-comment { color: #334155; font-style: italic; }

    /* ════════════════════════════════════════
       DISCIPLINES — The 5 pillars
    ════════════════════════════════════════ */
    #disciplines { background: var(--bg); }
    .disciplines-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(300px,1fr)); gap: 1.25rem; margin-top: 3.5rem; }
    .discipline-card {
      background: var(--bg-white); border: 1px solid var(--border);
      border-radius: var(--radius-lg); padding: 1.8rem;
      transition: border-color var(--transition), box-shadow var(--transition), transform var(--transition);
      position: relative; overflow: hidden;
    }
    .discipline-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: var(--teal); transform: scaleX(0); transform-origin: left;
      transition: transform 0.3s ease;
    }
    .discipline-card:hover { border-color: var(--teal-mid); box-shadow: var(--shadow-md); transform: translateY(-3px); }
    .discipline-card:hover::before { transform: scaleX(1); }

    .disc-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 1rem; }
    .disc-icon { font-size: 1.5rem; }
    .disc-tag {
      font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--teal);
      background: var(--teal-pale); border-radius: 3px;
      padding: 0.2rem 0.5rem;
    }
    .disc-title { font-family: var(--font-display); font-size: 1.05rem; font-weight: 700; color: var(--ink); margin-bottom: 0.5rem; }
    .disc-desc { font-size: 0.88rem; color: var(--ink-mid); line-height: 1.75; margin-bottom: 1.25rem; }
    .disc-list { display: flex; flex-direction: column; gap: 0.35rem; }
    .disc-item {
      font-family: var(--font-mono); font-size: 0.68rem; color: var(--ink-mid);
      display: flex; align-items: center; gap: 0.5rem;
    }
    .disc-item::before { content: '›'; color: var(--teal); font-size: 0.9rem; }

    /* GEO card gets a special glow */
    .discipline-card.featured {
      background: linear-gradient(135deg, #F0FDFA 0%, var(--bg-white) 60%);
      border-color: var(--teal-mid);
    }

    /* ════════════════════════════════════════
       CASE STUDIES
    ════════════════════════════════════════ */
    #work { background: var(--bg-white); }
    .work-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(320px,1fr)); gap: 1.5rem; margin-top: 3.5rem; }
    .work-card {
      border: 1px solid var(--border); border-radius: var(--radius-lg);
      overflow: hidden; background: var(--bg-white);
      transition: box-shadow var(--transition), transform var(--transition), border-color var(--transition);
    }
    .work-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-4px); border-color: var(--teal-mid); }

    .work-card-header {
      padding: 1.5rem 1.5rem 1.2rem;
      border-bottom: 1px solid var(--border);
    }
    .wc-meta { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem; }
    .wc-type {
      font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase;
      background: var(--teal-pale); color: var(--teal); border-radius: 3px; padding: 0.2rem 0.5rem;
    }
    .wc-industry {
      font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--ink-dim);
    }
